      <fx:SIGNAL ID="SIG_UPTIME_SEC">
        <ho:SHORT-NAME>uptime_sec</ho:SHORT-NAME>
        <fx:CODING-REF ID-REF="CODING_UINT32"/>
      </fx:SIGNAL>

    </fx:SIGNALS>

    <!-- ═══════════════════════════════════════════════════════
         CODINGS (base data types)
         ═══════════════════════════════════════════════════════ -->

    <fx:CODINGS>

      <fx:CODING ID="CODING_UINT8">
        <ho:SHORT-NAME>UINT8</ho:SHORT-NAME>
        <ho:CODED-TYPE ho:BASE-DATA-TYPE="A_UINT8" CATEGORY="STANDARD-LENGTH-TYPE">
          <ho:BIT-LENGTH>8</ho:BIT-LENGTH>
        </ho:CODED-TYPE>
      </fx:CODING>

      <fx:CODING ID="CODING_UINT16">
        <ho:SHORT-NAME>UINT16</ho:SHORT-NAME>
        <ho:CODED-TYPE ho:BASE-DATA-TYPE="A_UINT16" CATEGORY="STANDARD-LENGTH-TYPE">
          <ho:BIT-LENGTH>16</ho:BIT-LENGTH>
        </ho:CODED-TYPE>
      </fx:CODING>

      <fx:CODING ID="CODING_UINT32">
        <ho:SHORT-NAME>UINT32</ho:SHORT-NAME>
        <ho:CODED-TYPE ho:BASE-DATA-TYPE="A_UINT32" CATEGORY="STANDARD-LENGTH-TYPE">
          <ho:BIT-LENGTH>32</ho:BIT-LENGTH>
        </ho:CODED-TYPE>
      </fx:CODING>

      <fx:CODING ID="CODING_FLOAT32">
        <ho:SHORT-NAME>FLOAT32</ho:SHORT-NAME>
        <ho:CODED-TYPE ho:BASE-DATA-TYPE="A_FLOAT32" CATEGORY="STANDARD-LENGTH-TYPE">
          <ho:BIT-LENGTH>32</ho:BIT-LENGTH>
        </ho:CODED-TYPE>
      </fx:CODING>

    </fx:CODINGS>

  </fx:ELEMENTS>

</fx:FIBEX>