      <fx:SIGNAL ID="SIG_SENSOR_ID">
        <ho:SHORT-NAME>sensor_id</ho:SHORT-NAME>
        <fx:CODING-REF ID-REF="CODING_UINT8"/>
      </fx:SIGNAL>

      <fx:SIGNAL ID="SIG_RAW_ADC">
        <ho:SHORT-NAME>raw_adc</ho:SHORT-NAME>
        <fx:CODING-REF ID-REF="CODING_UINT16"/>
